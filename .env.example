# ============================================================
# Astra Environment Configuration
# ============================================================
# Copy this file to .env and fill in all values:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=astra
POSTGRES_PASSWORD=astra_dev
POSTGRES_DB=astra
DATABASE_URL=postgresql://astra:astra_dev@localhost:5432/astra

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Encryption ---
# 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Telegram ---
# Get from @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID. Send /start to @userinfobot to get it: https://t.me/userinfobot
TELEGRAM_ADMIN_CHAT_ID=

# --- Slack — AstroCat workspace (optional) ---
# Create a Slack app at https://api.slack.com/apps
# Enable Socket Mode, add Bot Token Scopes: chat:write, im:history, im:write, im:read,
#   channels:history, channels:read, groups:history, groups:read, users:read, users.profile:read, search:read
# Subscribe to bot events: message.im
# SLACK_AC_BOT_TOKEN=xoxb-...
# SLACK_AC_APP_TOKEN=xapp-...
# SLACK_AC_USER_TOKEN=xoxp-... (optional, preferred — sees private channels)
# SLACK_AC_ADMIN_USER_ID=U...
# SLACK_AC_TEAM_ID=T...

# --- Slack — Highground workspace (optional) ---
# Same setup as AC but for HG workspace
# SLACK_HG_BOT_TOKEN=xoxb-...
# SLACK_HG_APP_TOKEN=xapp-...
# SLACK_HG_USER_TOKEN=xoxp-...
# SLACK_HG_ADMIN_USER_ID=U...
# SLACK_HG_TEAM_ID=T...

# --- ClickUp Integration (optional) ---
# Personal API token from ClickUp Settings -> Apps
# CLICKUP_API_KEY=pk_xxxxxxx
# Team ID from ClickUp URL: app.clickup.com/{team_id}/...
# CLICKUP_TEAM_ID=1234567

# --- Google Workspace Integration (optional) ---
# OAuth 2.0 Client credentials from Google Cloud Console
# GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxx
# JSON array of authorized Google accounts (for multi-account briefing)
# GOOGLE_ACCOUNTS='["dariy@astrocat.co","dshatskikh@highground.games"]'

# --- Notion Integration (optional, read-only archive) ---
# Create integration at https://www.notion.so/my-integrations (Read content only)
# Share relevant pages with the integration
# NOTION_TOKEN=ntn_...

# --- Clockify Integration (optional, time tracking) ---
# API key from https://app.clockify.me/user/preferences (bottom of page)
# CLOCKIFY_API_KEY=xxxx
# Workspace ID from Settings -> General, or fetched via API
# CLOCKIFY_WORKSPACE_ID=xxxx

# --- Qdrant ---
QDRANT_URL=http://localhost:6333

# --- Claude ---
# Claude is accessed via the `claude` CLI (Max subscription OAuth).
# No API key needed — ensure `claude` is installed and authenticated on the host.

# --- Application ---
LOG_LEVEL=info
NODE_ENV=development
